{
  "name": "arche-language-server",
  "version": "0.1.0",
  "description": "LSP server for the Arche language — semantic-token highlighting derived from the arche compiler's own lexer",
  "license": "MIT",
  "type": "commonjs",
  "bin": {
    "arche-language-server": "out/server.js"
  },
  "main": "out/server.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsc -p .",
    "watch": "tsc -p . --watch"
  },
  "dependencies": {
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.12"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "@types/node": "^18.19.0"
  }
}
